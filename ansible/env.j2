# Environment Configuration
NODE_ENV=production
DEBUG=false

# Database Configuration
DB_HOST={{ db_host | default('localhost') }}
DB_PORT={{ db_port | default('5432') }}
DB_NAME={{ db_name | default('career_coach') }}
DB_USER={{ db_user | default('postgres') }}
DB_PASSWORD={{ db_password | default('password') }}

# Redis Configuration
REDIS_HOST={{ redis_host | default('localhost') }}
REDIS_PORT={{ redis_port | default('6379') }}

# JWT Configuration
JWT_SECRET={{ jwt_secret | default('your-super-secret-jwt-key') }}

# AI Service Configuration
AI_SERVICE_URL={{ ai_service_url | default('http://localhost:8000') }}

# CORS Configuration
CORS_ORIGIN={{ cors_origin | default('https://career-coach.example.com') }}

# File Upload Configuration
MAX_FILE_SIZE={{ max_file_size | default('10485760') }}
UPLOAD_DIR={{ upload_dir | default('uploads') }}

# Monitoring
PROMETHEUS_URL={{ prometheus_url | default('http://localhost:9090') }}
GRAFANA_URL={{ grafana_url | default('http://localhost:3001') }}
